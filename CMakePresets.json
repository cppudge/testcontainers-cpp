{
    "version": 3,
    "cmakeMinimumRequired": { "major": 3, "minor": 20, "patch": 0 },
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Default (Debug)",
            "description": "Configure with the vendored cmake-conan provider; deps installed automatically.",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "msvc",
            "displayName": "Visual Studio 2022 (x64)",
            "inherits": "default",
            "generator": "Visual Studio 17 2022",
            "architecture": "x64"
        }
    ],
    "buildPresets": [
        { "name": "default", "configurePreset": "default" },
        { "name": "msvc-debug", "configurePreset": "msvc", "configuration": "Debug" }
    ]
}
