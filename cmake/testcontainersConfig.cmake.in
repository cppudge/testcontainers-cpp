@PACKAGE_INIT@

# testcontainers is a static library whose third-party dependencies are
# PRIVATE, so consumers still need their link lines ($<LINK_ONLY:...> in the
# exported target). The dependency TARGET NAMES below follow Conan's CMakeDeps
# naming (Boost::headers, Libssh2::libssh2, ...) — the supported non-Conan
# consumption path is therefore "deps provided by `conan install`, library
# consumed via this config". Purely system-package dependency resolution would
# need find modules that reproduce those target names.
include(CMakeFindDependencyMacro)
# Prefer CONFIG packages while resolving OUR dependencies: CMake's built-in
# Find modules (FindLibArchive, FindBoost, ...) would otherwise shadow the
# Conan-generated configs sitting right in CMAKE_PREFIX_PATH — and only those
# define the target names the exported testcontainers target links against.
if(DEFINED CMAKE_FIND_PACKAGE_PREFER_CONFIG)
    set(_tc_saved_prefer_config "${CMAKE_FIND_PACKAGE_PREFER_CONFIG}")
endif()
set(CMAKE_FIND_PACKAGE_PREFER_CONFIG ON)
find_dependency(Boost)
find_dependency(nlohmann_json)
find_dependency(LibArchive)
# The feature set this library was BUILT with (TC_TLS /
# TC_HOST_PORT_FORWARDING), baked in at install time: only the dependencies
# its objects actually reference are resolved here.
if(@TC_TLS@ OR @TC_HOST_PORT_FORWARDING@)
    find_dependency(OpenSSL)
endif()
if(@TC_HOST_PORT_FORWARDING@)
    find_dependency(Libssh2)
endif()
if(NOT WIN32)
    find_dependency(Threads)
endif()
if(DEFINED _tc_saved_prefer_config)
    set(CMAKE_FIND_PACKAGE_PREFER_CONFIG "${_tc_saved_prefer_config}")
    unset(_tc_saved_prefer_config)
else()
    unset(CMAKE_FIND_PACKAGE_PREFER_CONFIG)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/testcontainersTargets.cmake")

check_required_components(testcontainers)
